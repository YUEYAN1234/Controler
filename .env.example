# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# JWT 签名密钥（必须修改为强随机字符串）
JWT_SECRET=change-me-to-a-secure-random-string

# 注册邀请码（团队成员需要此码才能注册）
INVITE_CODE=change-me

# 默认管理员密码（仅首次初始化数据库时有效）
ADMIN_PASSWORD=admin123

# 服务端口
PORT=3001

# 数据库文件路径（生产环境建议放在代码目录外）
# DB_PATH=/var/www/chemecar-data/data.db

# 上传文件存储路径（生产环境建议放在代码目录外）
# UPLOAD_DIR=/var/www/chemecar-data/uploads

# 运行环境
# NODE_ENV=production
