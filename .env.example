# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# JWT 签名密钥（生产环境必须修改为强随机字符串）
JWT_SECRET=replace-with-a-secure-random-string

# 注册邀请码（团队成员需要此码才能注册）
INVITE_CODE=replace-with-your-invite-code

# 默认管理员密码（仅首次初始化数据库时有效）
ADMIN_PASSWORD=replace-before-first-init

# 服务端口
PORT=3001

# 数据库文件路径（生产环境建议放在代码目录外）
# DB_PATH=/var/www/chemecar-data/data.db

# 上传文件存储路径（生产环境建议放在代码目录外）
# UPLOAD_DIR=/var/www/chemecar-data/uploads

# DeepSeek API 密钥（启用 Conter 智能助手时需要）
# DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

# OCR 语言包，多个语言用逗号分隔
# CHAT_OCR_LANGS=eng,chi_sim

# 运行环境
# NODE_ENV=production
